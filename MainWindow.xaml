<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RestReminder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RestReminder"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="休息提醒">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF8FAFC" Offset="0" />
                <GradientStop Color="#FFE2E8F0" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarArea" Height="48" Margin="16,12,16,0">
            <TextBlock
                Text="休息提醒"
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="1" Padding="32,20,32,32">
            <ScrollViewer
                HorizontalScrollMode="Disabled"
                VerticalScrollMode="Auto"
                VerticalScrollBarVisibility="Auto">
                <Border
                    CornerRadius="24"
                    Padding="28"
                    Background="#CCFFFFFF"
                    BorderBrush="#1A000000"
                    BorderThickness="1">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>

                    <StackPanel Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="每小时站起来活动一下"
                                FontSize="34"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Text="应用保持开启时，会按设定间隔弹出提醒；先点击“我去休息”停止提醒，再点击“我回来了”才会重新开始下一轮计时。"
                                FontSize="15"
                                Opacity="0.82"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="提醒间隔（分钟）" VerticalAlignment="Center" />
                            <NumberBox
                                Grid.Column="1"
                                x:Name="IntervalNumberBox"
                                HorizontalAlignment="Stretch"
                                MinWidth="120"
                                Minimum="1"
                                Maximum="720"
                                SpinButtonPlacementMode="Inline"
                                SmallChange="1"
                                Value="60" />
                            <Button Grid.Column="2" Content="应用间隔" Click="ApplyIntervalButton_Click" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="立刻触发" Click="TestMessageNotificationButton_Click" />
                            <Button Content="退出应用" Click="ExitButton_Click" />
                        </StackPanel>

                        <Border
                            CornerRadius="18"
                            Padding="18"
                            Background="#14FFFFFF"
                            BorderBrush="#24000000"
                            BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="状态" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock x:Name="IntervalText" Text="提醒间隔：-" TextWrapping="Wrap" />
                                <TextBlock x:Name="StatusText" Text="尚未启动" TextWrapping="Wrap" />
                                <TextBlock x:Name="NextReminderText" Text="下一次提醒：-" TextWrapping="Wrap" />
                                <TextBlock x:Name="CurrentReminderText" Text="当前提醒：-" TextWrapping="Wrap" />
                                <TextBlock x:Name="LastActionText" Text="最后动作：-" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>